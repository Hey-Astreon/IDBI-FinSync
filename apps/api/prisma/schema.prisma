datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum KycStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum RiskTier {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum GoalStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum InvestmentStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

enum TransactionCategory {
  FOOD
  UTILITIES
  RENT
  INVESTMENT
  ENTERTAINMENT
  SALARY
  OTHER
}

enum FundCategory {
  EQUITY
  DEBT
  HYBRID
  LIQUID
}

enum SipFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  mobileNumber  String    @unique
  passwordHash  String?
  kycStatus     KycStatus @default(PENDING)
  riskTier      RiskTier  @default(MODERATE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  preferences     UserPreferences?
  accounts        Account[]
  goals           Goal[]
  transactions    Transaction[]
  investments     Investment[]
  sips            Sip[]
  watchlists      Watchlist[]
  notifications   Notification[]
  conversations   AiConversation[]
  sessions        Session[]
  refreshTokens   RefreshToken[]
  otpVerifications OtpVerification[]
  deviceSessions  DeviceSession[]
  auditLogs       AuditLog[]

  @@map("users")
}

model UserPreferences {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @db.Uuid
  theme                String   @default("light")
  notificationsEnabled Boolean  @default(true)
  biometricsEnabled    Boolean  @default(false)
  baseCurrency         String   @default("INR")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Account {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  accountNumber String   @unique
  accountType   String   @default("SAVINGS") // e.g., SAVINGS, CURRENT
  balanceCents  BigInt   @default(0)
  currency      String   @default("INR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

model Goal {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  title        String
  targetCents  BigInt
  currentCents BigInt     @default(0)
  status       GoalStatus @default(DRAFT)
  streakCount  Int        @default(0)
  deadline     DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sips         Sip[]
  investments  Investment[]
  milestones   GoalMilestone[]

  @@index([userId])
  @@index([status])
  @@map("goals")
}

model GoalMilestone {
  id          String   @id @default(uuid()) @db.Uuid
  goalId      String   @db.Uuid
  percentage  Int
  isAchieved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_milestones")
}

model Transaction {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @db.Uuid
  accountId    String              @db.Uuid
  amountCents  BigInt
  type         TransactionType
  category     TransactionCategory
  merchantName String?
  timestamp    DateTime            @default(now())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp(sort: Desc)])
  @@index([accountId])
  @@map("transactions")
}

model MutualFund {
  id                     String       @id @default(uuid()) @db.Uuid
  name                   String
  category               FundCategory
  riskRating             RiskTier
  navCents               Int          // Net Asset Value in cents
  expenseRatioPercentage Decimal      @db.Decimal(5, 2)
  historicalReturn1y     Decimal      @db.Decimal(5, 2)
  historicalReturn3y     Decimal      @db.Decimal(5, 2)
  historicalReturn5y     Decimal      @db.Decimal(5, 2)
  isRecommended          Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  // Relations
  sips       Sip[]
  investments Investment[]
  watchlists Watchlist[]

  @@map("mutual_funds")
}

model Sip {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  goalId            String       @db.Uuid
  fundId            String       @db.Uuid
  amountCents       BigInt
  frequency         SipFrequency @default(MONTHLY)
  nextDeductionDate DateTime
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  fund        MutualFund   @relation(fields: [fundId], references: [id], onDelete: Cascade)
  investments Investment[]

  @@index([userId])
  @@index([goalId])
  @@index([fundId])
  @@map("sips")
}

model Investment {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @db.Uuid
  goalId         String           @db.Uuid
  sipId          String?          @db.Uuid // Nullable for manual one-time investments
  fundId         String?          @db.Uuid // Which mutual fund was purchased
  amountCents    BigInt
  status         InvestmentStatus @default(PENDING)
  unitsPurchased Decimal?         @db.Decimal(12, 4)
  transactionRef String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  sip  Sip?        @relation(fields: [sipId], references: [id], onDelete: SetNull)
  fund MutualFund? @relation(fields: [fundId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([goalId])
  @@index([sipId])
  @@index([fundId])
  @@map("investments")
}

model Watchlist {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  fundId     String   @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund MutualFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([userId, fundId])
  @@index([fundId])
  @@map("watchlists")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AiConversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  sender         String   // e.g. "USER", "MITRA"
  text           String
  intentDetected String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpVerification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  codeHash   String
  purpose    String    // e.g. "SIGNUP", "INVESTMENT_CONFIRM"
  expiresAt  DateTime
  status     OtpStatus @default(PENDING)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("otp_verifications")
}

model DeviceSession {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  deviceId   String
  deviceName String?
  ipAddress  String?
  isTrusted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("device_sessions")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid // Nullable for anonymous/failed login logs
  action    String   // e.g. "USER_LOGIN", "CREATE_SIP"
  details   String   // JSON string containing payload changes
  ipAddress String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}
