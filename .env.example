# Backend Configuration
PORT=5000
NODE_ENV=development

# Database Setup (PostgreSQL)
DATABASE_URL=postgresql://idbi_user:idbi_secure_password_2026@localhost:5432/idbi_finsync?schema=public

# Caching and Queues (Redis)
REDIS_URL=redis://localhost:6379

# Cryptographic Keys (JWT)
JWT_SECRET=replace_with_a_secure_random_string_32_characters
JWT_REFRESH_SECRET=replace_with_a_secure_random_refresh_string_64_characters

# AI Engine Credentials (Google Gemini API)
GEMINI_API_KEY=your_gemini_api_key_here
